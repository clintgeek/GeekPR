# GitHub App credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# LLM provider: "aigeek" (default), "openai", or "ollama"
DEFAULT_LLM_PROVIDER=aigeek

# aiGeek — baseGeek's OpenAI-compatible proxy
# Endpoint + API key: https://basegeek.clintgeek.com/openai/v1
# Generate a bg_<64-hex> key with the ai:call permission.
AIGEEK_BASE_URL=https://basegeek.clintgeek.com/openai/v1
AIGEEK_API_KEY=
# "<provider>/<model>" pins a specific backend per request.
# anthropic/claude-sonnet-4-6 gives consistent structured output.
AIGEEK_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Direct OpenAI access (testing only)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Ollama (local LLM — dev fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# Redis — shared datageek_redis on the suite's infra host (port 6380).
# db 2 is reserved for geekPR; db 0/1 are GeekSuite's. When running
# standalone, use redis://localhost:6379/0 and restore the redis:
# service in docker-compose.yml.
REDIS_URL=redis://192.168.1.17:6380/2

# Database — shared datageek_postgres (port 55432). For standalone use,
# switch back to sqlite:///./geekpr.db and restore the db: service.
DATABASE_URL=postgresql://datageek_pg_admin:PASSWORD@192.168.1.17:55432/geekpr

# Complexity threshold — functions with CC above this reach the LLM for
# severity triage. 15 = genuinely branchy code only. Lower if you want
# the reviewer to at least *look* at simpler functions (still won't post
# unless the LLM rates the finding CRITICAL or HIGH).
DEFAULT_CC_THRESHOLD=15
